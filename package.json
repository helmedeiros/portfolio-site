{
  "name": "ossified-osiris",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "pre-push": "npm run test:run && npm run build",
    "ci-check": "npm run test:run && npm run build && npm run preview -- --host 127.0.0.1 --port 4321"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.10",
    "astro": "^5.10.1",
    "tailwindcss": "^4.1.7"
  },
  "devDependencies": {
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^20.8.3",
    "jsdom": "^27.0.1",
    "vitest": "^4.0.18"
  }
}
